---
import { Image } from "astro:assets";
import ThemeToggle from "../ui/ThemeToggle/ThemeToggle.astro";

export interface Props {
    name: { first: string; last: string };
    title: string;
    subtitle: string;
    paragraph: string;
    experience?: string;
    location?: string;
    photo: ImageMetadata | string;
    photo2x?: ImageMetadata;
    linkedinUrl: string;
    githubUrl: string;
    cvUrl?: string;
    downloadCvText: string;
    hasBlogPosts?: boolean;
    homePath?: string;
    navigationLabels?: {
        skills: string;
        projects: string;
        blog: string;
        contact: string;
        about: string;
    };
    mobileMenuAriaLabel?: string;
    toggleMenuText?: string;
    socialAriaLabels?: {
        linkedin: string;
        github: string;
    };
    downloadCvAriaLabel?: string;
    portraitAltText?: string;
    languageSwitch?: {
        currentLocale: "en" | "es";
        enHref: string;
        esHref: string;
        enLabel: string;
        esLabel: string;
        ariaLabel: string;
    };
}

const {
    name,
    title,
    subtitle,
    paragraph,
    experience,
    location,
    photo,
    linkedinUrl,
    githubUrl,
    cvUrl,
    downloadCvText,
    hasBlogPosts = true,
    homePath = "/",
    navigationLabels = {
        skills: "Skills",
        projects: "Projects",
        blog: "Blog",
        contact: "Contact",
        about: "About",
    },
    mobileMenuAriaLabel = "Toggle primary navigation menu",
    toggleMenuText = "Toggle menu",
    socialAriaLabels = {
        linkedin: "Visit my LinkedIn profile",
        github: "Visit my GitHub profile",
    },
    downloadCvAriaLabel = "Download my CV (opens in new tab)",
    portraitAltText = `Portrait of ${name.first} ${name.last}`,
    languageSwitch = {
        currentLocale: "en",
        enHref: "/",
        esHref: "/es",
        enLabel: "EN",
        esLabel: "ES",
        ariaLabel: "Language switch",
    },
} = Astro.props;

const sectionLinks = [
	{ href: "#skills", label: navigationLabels.skills },
	{ href: "#projects", label: navigationLabels.projects },
	...(hasBlogPosts ? [{ href: "#blog", label: navigationLabels.blog }] : []),
	{ href: "#contact", label: navigationLabels.contact },
	{ href: "#faq", label: navigationLabels.about },
];

const languageSwitchHref =
	languageSwitch.currentLocale === "en" ? languageSwitch.esHref : languageSwitch.enHref;
const languageSwitchTargetLocaleLabel =
	languageSwitch.currentLocale === "en" ? languageSwitch.esLabel : languageSwitch.enLabel;
const languageSwitchIconAriaLabel = `${languageSwitch.ariaLabel}: ${languageSwitchTargetLocaleLabel}`;

const mobileMenuId = "header-mobile-menu";
const mobileMenuButtonId = "header-mobile-menu-button";
---

<header
    class="relative z-20 p-5 flex flex-col items-center justify-center mb-16"
    role="banner"
>
    <div class="relative z-40 w-full max-w-[50rem] mb-16">
    <nav
        class="w-full flex justify-between items-center"
        aria-label="Primary navigation"
    >
		<div class="flex items-center gap-3 md:gap-4">
			<a
				href={languageSwitchHref}
				class="hidden md:inline-flex h-9 min-w-9 px-2 items-center justify-center border border-text-base text-text-base text-[0.7rem] leading-none font-mono uppercase tracking-[0.08rem] transition-colors hover:text-link-hover focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-text-base/60 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent rounded-sm"
				aria-label={languageSwitchIconAriaLabel}
				title={languageSwitchTargetLocaleLabel}
			>
				{languageSwitchTargetLocaleLabel}
			</a>
			<a
				href={homePath}
				class="text-text-base font-sans text-[1.13rem] hover:opacity-80 transition-opacity"
			>
				{name.first}
				<span class="font-bold">{name.last}.</span>
			</a>
		</div>
		<div class="flex items-center gap-4 md:gap-0">
			<ul class="hidden md:flex flex-wrap items-center justify-end gap-5 lg:gap-8 text-[0.65rem] sm:text-[0.75rem] font-mono uppercase tracking-[0.12rem] max-w-[18rem] sm:max-w-none">
				{sectionLinks.map((link) => (
					<li>
						<a href={link.href} class="inline-flex items-center gap-1.5 hover:text-link-hover transition-colors">
							<span>{link.label}</span>
						</a>
					</li>
				))}
			</ul>
			<button
				type="button"
				id={mobileMenuButtonId}
				class="md:hidden cursor-pointer rounded-md border border-border-base bg-white/20 dark:bg-white/5 p-2 text-text-base shadow-sm backdrop-blur-xl transition-colors"
				aria-expanded="false"
				aria-controls={mobileMenuId}
				aria-label={mobileMenuAriaLabel}
			>
				<span class="sr-only">{toggleMenuText}</span>
				<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<line class="menu-icon-line menu-icon-line-top" x1="4" y1="7" x2="20" y2="7" stroke-linecap="round" />
					<line class="menu-icon-line menu-icon-line-middle" x1="4" y1="12" x2="20" y2="12" stroke-linecap="round" />
					<line class="menu-icon-line menu-icon-line-bottom" x1="4" y1="17" x2="20" y2="17" stroke-linecap="round" />
				</svg>
			</button>
			<div class="md:ml-4">
				<ThemeToggle />
			</div>
		</div>
    </nav>

	<div
		id={mobileMenuId}
		class="md:hidden absolute top-full mt-6 left-4 right-4 mx-auto z-[70] origin-top scale-y-0 transform-gpu transition-transform duration-300 ease-out pointer-events-none"
	>
		<div class="mobile-menu-panel relative isolate overflow-hidden rounded-xl text-text-base shadow-2xl p-4">
			<div class="mobile-menu-tint pointer-events-none absolute inset-0"></div>
			<ul class="relative z-10 flex flex-col gap-3 text-[0.7rem] font-mono uppercase tracking-[0.12rem]">
				{sectionLinks.map((link) => (
					<li>
						<a href={link.href} class="mobile-nav-link inline-flex items-center gap-2 py-1 hover:text-link-hover transition-colors">
							<span>{link.label}</span>
						</a>
					</li>
				))}
				<li class="pt-2 border-t border-border-base/40">
					<a
						href={languageSwitchHref}
						class="mobile-nav-link inline-flex h-10 min-w-10 px-3 items-center justify-center border border-text-base text-text-base text-[0.75rem] leading-none font-mono uppercase tracking-[0.08rem] transition-colors hover:text-link-hover focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-text-base/60 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent rounded-sm"
						aria-label={languageSwitchIconAriaLabel}
						title={languageSwitchTargetLocaleLabel}
					>
						{languageSwitchTargetLocaleLabel}
					</a>
				</li>
			</ul>
		</div>
	</div>
    </div>

    <figure
        class="rounded-full border-[3px] border-text-base mb-6 flex items-center justify-center transition-colors duration-300 overflow-hidden bg-white/5"
    >
        {
            typeof photo === "string" ? (
                <img
                    class="rounded-full w-[200px] h-[200px] md:w-[375px] md:h-[375px] object-cover aspect-square"
                    src={photo}
                    alt={portraitAltText}
                    loading="eager"
                    decoding="async"
                />
            ) : (
                <Image
                    class="rounded-full w-[200px] h-[200px] md:w-[375px] md:h-[375px] object-cover aspect-square"
                    src={photo}
                    width={375}
                    height={375}
                    alt={portraitAltText}
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                />
            )
        }
    </figure>

	<div class="text-center mb-6 text-text-base transition-colors duration-300 max-w-[min(95vw,48rem)] sm:max-w-[56rem] mx-auto px-0 sm:px-0">
		<h1
			class="hero-title-intro text-[clamp(1.72rem,8.15vw,3.5rem)] sm:text-[clamp(2.4rem,6vw,3.5rem)] font-bold leading-[1.05] sm:leading-tight tracking-[-0.01em] break-words sm:whitespace-nowrap"
		>
			{title}
		</h1>
		{
			subtitle && !title.includes(subtitle) && (
				<p class="text-[clamp(1.72rem,8.15vw,3.625rem)] sm:text-[clamp(2.4rem,6vw,3.625rem)] font-bold leading-[1.05] sm:leading-tight tracking-[-0.01em] mt-1 break-words">
					<span class="hero-subtitle-wrap">
						<span class="hero-subtitle-typed">{subtitle}</span>
					</span>
                </p>
            )
        }
    </div>
    {subtitle && title.includes(subtitle) && <p class="sr-only">{subtitle}</p>}

    <div
        class="text-[1.13rem] text-center leading-[1.5625rem] max-w-[40rem] font-sans text-text-muted mb-6"
    >
        <p>{paragraph}</p>
        {experience && <p>{experience}</p>}
        {location && <p>{location}</p>}
    </div>

    <nav class="flex gap-4 mb-6" aria-label="Social media links">
        <a
            href={linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-base hover:scale-125 transition-transform inline-block"
            aria-label={socialAriaLabels.linkedin}
        >
            <svg
                class="w-6 h-6"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
            >
                <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
            </svg>
        </a>
        <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-base hover:scale-125 transition-transform inline-block"
            aria-label={socialAriaLabels.github}
        >
            <svg
                class="w-6 h-6"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
            >
                <path
                    fill-rule="evenodd"
                    d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                    clip-rule="evenodd"></path>
            </svg>
        </a>
    </nav>

    {
        cvUrl && cvUrl !== "#" && (
            <a
                href={cvUrl}
                target="_blank"
                rel="noopener noreferrer"
                class={`
          px-5 py-3 bg-accent-hover text-black dark:text-black font-bold rounded-md
          hover:scale-110 transition-transform
          font-display text-[1.13rem]
        `}
                aria-label={downloadCvAriaLabel}
            >
                {downloadCvText}
            </a>
        )
    }
</header>

<script
    is:inline
    define:vars={{
        name,
        title,
        subtitle,
        paragraph,
        experience,
        location,
        linkedinUrl,
        githubUrl,
        mobileMenuId,
        mobileMenuButtonId,
    }}
>
    const setupHeaderMobileMenu = () => {
        const menuButton = document.getElementById(mobileMenuButtonId);
        const menu = document.getElementById(mobileMenuId);

        if (!(menuButton instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) {
            return;
        }

        if (menuButton.dataset.menuReady === "true") {
            return;
        }
        menuButton.dataset.menuReady = "true";

        const setMenuState = (isOpen) => {
            menuButton.setAttribute("aria-expanded", String(isOpen));
            menu.classList.toggle("scale-y-100", isOpen);
            menu.classList.toggle("pointer-events-auto", isOpen);
            menu.classList.toggle("scale-y-0", !isOpen);
            menu.classList.toggle("pointer-events-none", !isOpen);
        };

        menuButton.addEventListener("click", () => {
            const isExpanded = menuButton.getAttribute("aria-expanded") === "true";
            setMenuState(!isExpanded);
        });

        menu.querySelectorAll(".mobile-nav-link").forEach((link) => {
            link.addEventListener("click", () => setMenuState(false));
        });
    };

    setupHeaderMobileMenu();
    document.addEventListener("astro:after-swap", setupHeaderMobileMenu);

    // Ensure variables are "used" for static analysis
    console.debug("Header initialized");
</script>

<style>
	#header-mobile-menu-button .menu-icon-line {
		transform-box: fill-box;
		transform-origin: center;
		transition: transform 200ms ease, opacity 200ms ease;
	}

	#header-mobile-menu-button[aria-expanded="true"] .menu-icon-line-top {
		transform: translateY(5px) rotate(45deg);
	}

	#header-mobile-menu-button[aria-expanded="true"] .menu-icon-line-middle {
		opacity: 0;
	}

	#header-mobile-menu-button[aria-expanded="true"] .menu-icon-line-bottom {
		transform: translateY(-5px) rotate(-45deg);
	}
</style>
