---
/**
 * @file Header.astro
 * @description Hero section component with profile photo, name, bio, social links, and CV download.
 * Follows semantic HTML best practices with a single H1 per usage context.
 */

import { Image } from "astro:assets";
import ThemeToggle from "../atoms/ThemeToggle/ThemeToggle.astro";

interface Props {
  /** Object containing first and last name for the logo */
  name: { first: string; last: string };
  /** Main headline (H1) */
  title: string;
  /** Secondary headline (styled paragraph, not H1) */
  subtitle: string;
  /** Bio paragraph text */
  paragraph: string;
  /** Profile photo - ImageMetadata for Astro optimization */
  photo: ImageMetadata;
  /** 2x resolution photo for retina displays - ImageMetadata for Astro optimization */
  photo2x?: ImageMetadata;
  /** LinkedIn profile URL */
  linkedinUrl: string;
  /** GitHub profile URL */
  githubUrl: string;
  /** Optional CV download URL */
  cvUrl?: string;
}

const {
  name,
  title,
  subtitle,
  paragraph,
  photo,
  photo2x,
  linkedinUrl,
  githubUrl,
  cvUrl,
} = Astro.props;
---

<header
  class="p-5 flex flex-col items-center justify-center mb-[6.25rem]"
  role="banner"
>
  <!-- Top Navigation Bar -->
  <nav
    class="w-full max-w-[50rem] mb-5 flex justify-between items-center"
    aria-label="Primary navigation"
  >
    <a
      href="/"
      class="text-text-base font-sans text-[1.13rem] hover:opacity-80 transition-opacity"
    >
      {name.first}
      <span class="font-bold">{name.last}.</span>
    </a>
    <ThemeToggle />
  </nav>

  <!-- Hero Section -->
  <section
    class="flex flex-col items-center text-text-base font-display max-w-[50rem]"
    aria-label="About me"
  >
    <!-- 
      Hero image with proper aspect ratio (1:1) and retina support.
      Using fixed dimensions to prevent CLS and aspect ratio issues.
      srcset provides 2x resolution for retina displays.
    -->
    <figure
      class="rounded-full border-[3px] border-text-base mb-10 flex items-center justify-center transition-colors duration-300 overflow-hidden bg-white/5"
    >
      <Image
        class="rounded-full w-[200px] h-[200px] md:w-[375px] md:h-[375px] object-cover aspect-square"
        src={photo}
        width={375}
        height={375}
        alt={`Portrait of ${name.first} ${name.last}, Front End Developer`}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </figure>

    <div class="text-center mb-7 text-text-base transition-colors duration-300">
      <h1 class="text-[clamp(2.8rem,5vw,3.625rem)] font-bold leading-[1.2]">
        {title}
      </h1>
      {
        subtitle && !title.includes(subtitle) && (
          <p class="text-[clamp(2.8rem,5vw,3.625rem)] font-bold leading-[1.2] mt-1">
            {subtitle}
          </p>
        )
      }
    </div>

    <p
      class="text-[1.13rem] text-center leading-[1.5625rem] max-w-[40rem] font-sans text-text-muted"
    >
      {paragraph}
    </p>

    <!-- Social Links (inline SVGs to avoid Font Awesome dependency) -->
    <nav class="flex gap-4 my-4" aria-label="Social media links">
      <a
        href={linkedinUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-base hover:scale-125 transition-transform inline-block"
        aria-label="Visit my LinkedIn profile"
      >
        <svg
          class="w-6 h-6"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
      </a>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-base hover:scale-125 transition-transform inline-block"
        aria-label="Visit my GitHub profile"
      >
        <svg
          class="w-6 h-6"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
    </nav>

    <!-- CTA Button -->
    {
      cvUrl && cvUrl !== "#" && (
        <a
          href={cvUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-3 bg-accent text-black font-bold rounded-md
                 hover:bg-accent-hover hover:scale-110 transition-transform font-display mt-4 text-[1.13rem]"
          aria-label="Download my CV (opens in new tab)"
        >
          Download my CV
        </a>
      )
    }
  </section>
</header>
