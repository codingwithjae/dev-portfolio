---
import type { BlogPost } from "../../lib/sanity/sanity.types";
import Footer from "../sections/Footer.astro";
import BlogCard from "../ui/cards/BlogCard.astro";

export interface Props {
    posts: BlogPost[];
    homePath?: string;
    blogBasePath?: string;
    labels?: {
        navigationAriaLabel: string;
        backToHome: string;
        pageTitle: string;
        pageDescription: string;
        emptyState: string;
        feedAriaLabel: string;
        readMore: string;
    };
    footer: {
        authorName: string;
        copyrightText: string;
        repoText: {
            pre: string;
            link: string;
            post: string;
        };
    };
    socialLinks: {
        linkedinUrl: string;
        githubUrl: string;
        repoUrl: string;
    };
    languageSwitch?: {
        currentLocale: "en" | "es";
        enHref: string;
        esHref: string;
        enLabel: string;
        esLabel: string;
        ariaLabel: string;
    };
}

const {
    posts,
    homePath = "/",
    blogBasePath = "/blog",
    labels = {
        navigationAriaLabel: "Blog navigation",
        backToHome: "← Back to Home",
        pageTitle: "Blog",
        pageDescription: "Thoughts, tutorials, and insights on frontend development.",
        emptyState: "No blog posts yet. Coming soon!",
        feedAriaLabel: "Blog posts",
        readMore: "Read more",
    },
    footer,
    socialLinks,
    languageSwitch = {
        currentLocale: "en",
        enHref: "/blog",
        esHref: "/es/blog",
        enLabel: "EN",
        esLabel: "ES",
        ariaLabel: "Language switch",
    },
} = Astro.props;
---

<header
    class="p-5 flex flex-col items-center justify-center mb-12"
    role="banner"
>
    <nav
        class="w-full max-w-4xl mb-5 flex justify-between items-center"
        aria-label={labels.navigationAriaLabel}
    >
        <a
            href={homePath}
            class="text-text-base font-sans text-[1.13rem] hover:opacity-80 transition-opacity"
        >
            Johander <span class="font-bold">Campos.</span>
        </a>
        <div class="flex items-center gap-4">
            <a href={homePath} class="font-bold hover:text-link-hover transition-colors"
                >{labels.backToHome}</a
            >
            <div class="inline-flex items-center gap-1 text-[0.68rem] font-mono uppercase tracking-[0.12rem]" aria-label={languageSwitch.ariaLabel}>
                <a
                    href={languageSwitch.enHref}
                    class={`px-2 py-1 rounded border transition-colors ${
                        languageSwitch.currentLocale === "en"
                            ? "border-border-base bg-white/20 dark:bg-white/10 text-text-base"
                            : "border-border-base/40 text-text-muted hover:text-link-hover"
                    }`}
                >
                    {languageSwitch.enLabel}
                </a>
                <span class="text-text-muted">/</span>
                <a
                    href={languageSwitch.esHref}
                    class={`px-2 py-1 rounded border transition-colors ${
                        languageSwitch.currentLocale === "es"
                            ? "border-border-base bg-white/20 dark:bg-white/10 text-text-base"
                            : "border-border-base/40 text-text-muted hover:text-link-hover"
                    }`}
                >
                    {languageSwitch.esLabel}
                </a>
            </div>
        </div>
    </nav>
</header>

<main
    class="max-w-4xl mx-auto p-5 min-h-screen transition-colors"
    id="main-content"
>
    <div class="mb-10 text-center reveal">
        <h1
            class="text-[clamp(2.5rem,5vw,3.625rem)] font-display font-bold text-text-base"
        >
            {labels.pageTitle}
        </h1>
        <p class="text-text-base mt-2 text-lg">
            {labels.pageDescription}
        </p>
    </div>

    {
        posts.length === 0 ? (
            <p class="text-text-muted text-center py-20 reveal">
                {labels.emptyState}
            </p>
        ) : (
            <div class="grid gap-8" role="feed" aria-label={labels.feedAriaLabel}>
                {posts.map((post, index) => (
                    <article
                        class={`reveal delay-${((index % 4) + 1) * 100} w-full`}
                    >
                        <BlogCard
                            title={post.title}
                            excerpt={post.excerpt || ""}
                            slug={post.slug}
                            blogBasePath={blogBasePath}
                            readMoreText={labels.readMore}
                            coverImage={post.coverImage}
                        />
                    </article>
                ))}
            </div>
        )
    }
</main>

<Footer
    linkedinUrl={socialLinks.linkedinUrl}
    githubUrl={socialLinks.githubUrl}
    repoUrl={socialLinks.repoUrl}
    authorName={footer.authorName}
    copyrightText={footer.copyrightText}
    repoText={footer.repoText}
/>
