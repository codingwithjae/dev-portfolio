---
import Footer from "../components/sections/Footer.astro";
import ExperienceSection from "../components/sections/ExperienceSection.astro";
import ThemeToggle from "../components/ui/ThemeToggle/ThemeToggle.astro";
import { getStaticData } from "../data/staticData";
import { resolveLocaleFromRequest } from "../i18n/utils";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent } from "../lib/sanity/sanity";
import type { PageContent } from "../lib/sanity/sanity.types";
import { resolveAboutContent, resolveExperience } from "../lib/sanity/transform";

const locale = resolveLocaleFromRequest(Astro.url);
const localizedStaticData = getStaticData(locale);
const localeHomePath = locale === "es" ? "/es" : "/";
const localeBlogPath = locale === "es" ? "/es/blog" : "/blog";
const aboutLanguageSwitch = {
	enHref: "/about",
	esHref: "/es/about",
	currentLocale: locale,
	ariaLabel: locale === "es" ? "Cambiar idioma" : "Switch language",
} as const;

let homePageContent: PageContent | null = null;

try {
	homePageContent = await getPageContent(locale);
} catch (fetchError) {
	console.error("Sanity data fetch failed:", fetchError);
}

const aboutContent = resolveAboutContent(homePageContent, locale);
const experience = resolveExperience(homePageContent, locale);

const aboutParagraphs = aboutContent.details
	.split("\n")
	.map((paragraph) => paragraph.trim())
	.filter(Boolean);
---

<BaseLayout
	locale={locale}
	title="About"
	description="Background, independent projects, and writing by Johander Campos."
>
	<header class="p-5 flex flex-col items-center justify-center mb-[3rem]" role="banner">
		<nav class="w-full max-w-[50rem] mb-5 flex justify-between items-center" aria-label="About navigation">
			<a href={localeHomePath} class="text-text-base font-sans text-[1.13rem] hover:opacity-80 transition-opacity">
				Johander <span class="font-bold">Campos.</span>
			</a>
			<div class="flex items-center gap-4">
				<div class="inline-flex items-center gap-1 text-[0.68rem] font-mono uppercase tracking-[0.12rem]" aria-label={aboutLanguageSwitch.ariaLabel}>
					<a
						href={aboutLanguageSwitch.enHref}
						class={`px-2 py-1 rounded border transition-colors ${
							aboutLanguageSwitch.currentLocale === "en"
								? "border-border-base bg-white/20 dark:bg-white/10 text-text-base"
								: "border-border-base/40 text-text-muted hover:text-link-hover"
						}`}
					>
						EN
					</a>
					<span class="text-text-muted">/</span>
					<a
						href={aboutLanguageSwitch.esHref}
						class={`px-2 py-1 rounded border transition-colors ${
							aboutLanguageSwitch.currentLocale === "es"
								? "border-border-base bg-white/20 dark:bg-white/10 text-text-base"
								: "border-border-base/40 text-text-muted hover:text-link-hover"
						}`}
					>
						ES
					</a>
				</div>
				<a href={localeHomePath} class="font-bold hover:text-link-hover transition-colors">
					{locale === "es" ? "Inicio" : "Home"}
				</a>
				<a href={localeBlogPath} class="font-bold hover:text-link-hover transition-colors">Blog</a>
				<ThemeToggle />
			</div>
		</nav>
	</header>

	<main class="p-5 flex flex-col justify-center items-center text-text-base overflow-x-hidden transition-colors" id="main-content">
		<section class="w-full max-w-[50rem] mb-16" aria-labelledby="about-heading">
			<div class="w-full mb-10 reveal">
				<h1 id="about-heading" class="text-[clamp(2.5rem,5vw,3.625rem)] font-display font-bold">
					{aboutContent.title}
				</h1>
				<p class="text-text-muted mt-2 font-sans">{aboutContent.intro}</p>
			</div>

			<div class="glassmorphism rounded-[1.25rem] p-6 md:p-8 reveal delay-100">
				{aboutParagraphs.map((paragraph) => (
					<p class="font-sans text-text-base leading-relaxed mb-4 last:mb-0">{paragraph}</p>
				))}
			</div>
		</section>

		<ExperienceSection items={experience} />
	</main>

	<Footer
		linkedinUrl={localizedStaticData.header.socials.linkedin}
		githubUrl={localizedStaticData.header.socials.github}
		repoUrl={localizedStaticData.header.repoUrl}
		authorName={localizedStaticData.footer.author}
		copyrightText={localizedStaticData.footer.copyright}
		repoText={localizedStaticData.footer.repoText}
	/>
</BaseLayout>
