---
import { getImage } from "astro:assets";
import photoImage from "../assets/images/portrait.webp";
import { ContactForm } from "../components/sections/ContactForm";
import Footer from "../components/sections/Footer.astro";
import Header from "../components/sections/Header.astro";
import BlogCard from "../components/ui/cards/BlogCard.astro";
import ProjectCard from "../components/ui/cards/ProjectCard.astro";
import { SkillCard } from "../components/ui/cards/SkillCard";
import { FaqItem } from "../components/ui/FaqItem/FaqItem";
import BackToTop from "../components/ui/BackToTop/BackToTop.astro";
import { getStaticData } from "../data/staticData";
import { resolveLocaleFromRequest } from "../i18n/utils";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getFeaturedBlogPosts, getPageContent } from "../lib/sanity/sanity";
import type { BlogPost, PageContent, UIProject } from "../lib/sanity/sanity.types";
import { getHomeSchema } from "../components/seo/sanity-seo";
import {
  mapSanityProjectsToUI,
  groupProjectsByCategory,
  resolveSkillCategories,
  extractHomeSEO,
  extractAuthorHeader,
  resolveFaqContent,
  PROJECT_CATEGORIES_ORDER,
  CATEGORY_DISPLAY_NAMES,
} from "../lib/sanity/transform";

const locale = resolveLocaleFromRequest(Astro.url);
const localizedStaticData = getStaticData(locale);

let homePageContent: PageContent | null = null;
let featuredBlogPosts: BlogPost[] = [];

try {
  const [content, posts] = await Promise.all([
		getPageContent(locale),
		getFeaturedBlogPosts(locale),
  ]);
  homePageContent = content;
  featuredBlogPosts = posts;
} catch (fetchError) {
  console.error("Sanity data fetch failed:", fetchError);
}
const skillCategories = resolveSkillCategories(homePageContent, locale);
const portfolioProjects = mapSanityProjectsToUI(homePageContent?.projects, locale);
const projectsByCategory = groupProjectsByCategory(portfolioProjects);
const orderedProjectCategories = [
  ...PROJECT_CATEGORIES_ORDER,
  ...Object.keys(projectsByCategory).filter(
    (category) =>
      !PROJECT_CATEGORIES_ORDER.includes(
        category as (typeof PROJECT_CATEGORIES_ORDER)[number],
      ),
  ),
];
const faqContent = resolveFaqContent(homePageContent, locale);

const optimizedPersonImage = await getImage({
  src: photoImage,
  width: 375,
  height: 375,
  format: "webp",
});

const {
  title: pageTitle,
  description: pageDescription,
  ogImage,
  noindex: pageNoindex,
} = extractHomeSEO(homePageContent, locale);
const headerData = extractAuthorHeader(homePageContent, locale);
const heroPhoto = headerData.portrait || photoImage;

const combinedJsonLd = getHomeSchema(
  homePageContent,
  localizedStaticData,
  optimizedPersonImage.src,
  locale,
);

const localeHomePath = locale === "es" ? "/es" : "/";
const localeBlogPath = locale === "es" ? "/es/blog" : "/blog";
const resolvedCvUrl =
  locale === "es"
    ? homePageContent?.cvUrlEs || homePageContent?.cvUrl || localizedStaticData.header.cvUrl
    : homePageContent?.cvUrl || localizedStaticData.header.cvUrl;
const homeLanguageSwitch = {
  currentLocale: locale,
  enHref: "/",
  esHref: "/es",
  enLabel: "EN",
  esLabel: "ES",
  ariaLabel: locale === "es" ? "Cambiar idioma" : "Switch language",
} as const;
---

<BaseLayout
  locale={locale}
  title={pageTitle}
  description={pageDescription}
  ogImage={ogImage}
  noindex={pageNoindex}
  jsonLd={combinedJsonLd}
  {...(!headerData.portrait ? { preloadHeroImage: photoImage } : {})}
>
  <Header
    name={headerData.name}
    title={headerData.title}
    subtitle={headerData.subtitle}
    paragraph={headerData.bio}
    photo={heroPhoto}
    linkedinUrl={localizedStaticData.header.socials.linkedin}
    githubUrl={localizedStaticData.header.socials.github}
    cvUrl={resolvedCvUrl}
    downloadCvText={localizedStaticData.header.downloadCv}
    homePath={localeHomePath}
    navigationLabels={{
      skills: locale === "es" ? "Habilidades" : "Skills",
      projects: locale === "es" ? "Proyectos" : "Projects",
      blog: "Blog",
      contact: locale === "es" ? "Contacto" : "Contact",
      about: localizedStaticData.home.faq.title,
    }}
    mobileMenuAriaLabel={
      locale === "es" ? "Abrir menu de navegacion principal" : "Toggle primary navigation menu"
    }
    toggleMenuText={locale === "es" ? "Abrir menu" : "Toggle menu"}
    socialAriaLabels={{
      linkedin:
        locale === "es" ? "Visitar mi perfil de LinkedIn" : "Visit my LinkedIn profile",
      github: locale === "es" ? "Visitar mi perfil de GitHub" : "Visit my GitHub profile",
    }}
    downloadCvAriaLabel={
      locale === "es" ? "Descargar mi CV (se abre en una nueva pestana)" : "Download my CV (opens in new tab)"
    }
    portraitAltText={
      locale === "es"
        ? `Retrato de ${headerData.name.first} ${headerData.name.last}`
        : `Portrait of ${headerData.name.first} ${headerData.name.last}`
    }
    hasBlogPosts={featuredBlogPosts.length > 0}
    languageSwitch={homeLanguageSwitch}
  />

  <main
    class="p-5 flex flex-col justify-center items-center text-text-base overflow-x-hidden transition-colors"
    id="main-content"
  >
    <section
      id="skills"
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-5 max-w-200 w-full mb-16 lg:self-center"
      aria-labelledby="skills-heading"
    >
      <h2 id="skills-heading" class="sr-only">{localizedStaticData.home.skillsTitle}</h2>
      {
        skillCategories.map((skillCategory, index: number) => {
          if (
            !skillCategory?.skills ||
            !Array.isArray(skillCategory.skills) ||
            skillCategory.skills.length === 0
          )
            return null;
          const firstSkill = skillCategory.skills[0];
          if (!firstSkill) return null;
          const skillsForTicker = [
            ...skillCategory.skills,
            firstSkill,
          ];
          return (
            <div class={`reveal delay-${(index + 1) * 100}`}>
              <SkillCard
                client:visible
                category={skillCategory.category}
                skills={skillsForTicker}
                locale={locale}
              />
            </div>
          );
        })
      }
    </section>

    {
      portfolioProjects.length > 0 && (
        <section
          id="projects"
          class="flex flex-col justify-center items-center w-full max-w-200 mb-16"
          aria-labelledby="projects-heading"
        >
          <div class="w-full mb-16 reveal">
            <h2
              id="projects-heading"
              class="text-[clamp(2.5rem,5vw,3.625rem)] font-display font-bold"
            >
              {localizedStaticData.home.projects.title}
            </h2>
            <p class="text-text-muted mt-2 font-sans">
              {localizedStaticData.home.projects.description}
            </p>
          </div>

          {orderedProjectCategories.map((cat) => {
            const categoryProjects = projectsByCategory[cat] || [];
            if (categoryProjects.length === 0) return null;

            return (
              <div class="w-full mb-16 last:mb-0">
                <div class="flex items-center gap-4 mb-16 reveal">
                  <h3 class="text-2xl font-display font-bold text-text-base">
                    {CATEGORY_DISPLAY_NAMES[cat] || cat}
                  </h3>
                  <div class="h-px flex-1 bg-border-base/30" />
                  <span class="text-[10px] font-mono text-text-base font-bold uppercase tracking-[0.2em]">
                    {categoryProjects.length}{" "}
                    {categoryProjects.length === 1
                      ? localizedStaticData.home.projects.projectCount
                      : localizedStaticData.home.projects.projectsCount}
                  </span>
                </div>

                <div
                  class={`${
                    categoryProjects.length === 1
                      ? "flex justify-center"
                      : "grid grid-cols-1 md:grid-cols-2"
                  } gap-6 w-full items-start`}
                >
                  {categoryProjects.map((project: UIProject, index: number) => (
                    <article
                      class={`reveal delay-${(index + 1) * 100} h-full ${
                        categoryProjects.length === 1 ? "w-full max-w-lg" : ""
                      }`}
                    >
                      <ProjectCard
                        title={project.title}
                        thumbnail={project.thumbnail}
                        technologies={project.technologies}
                        demoUrl={project.demoUrl}
                        codeUrl={project.codeUrl}
                        documentationUrl={project.documentationUrl}
                        viewProjectText={localizedStaticData.home.projects.viewProject}
                        viewDocumentationText={localizedStaticData.home.projects.viewDocumentation}
                        viewCodeText={localizedStaticData.home.projects.viewCode}
                      />
                    </article>
                  ))}
                </div>
              </div>
            );
          })}
        </section>
      )
    }

    {
      featuredBlogPosts.length > 0 && (
        <section
          id="blog"
          class="flex flex-col justify-center items-center w-full max-w-200 mb-16"
          aria-labelledby="blog-heading"
        >
          <div class="w-full flex justify-between items-center mb-16 reveal">
            <h2
              id="blog-heading"
              class="text-[clamp(2.8rem,5vw,3.625rem)] font-display font-bold text-left w-full"
            >
              {localizedStaticData.home.blog.title}
            </h2>
          </div>
          <div class="flex flex-col justify-center items-center gap-16 w-full">
            {featuredBlogPosts.map((post: BlogPost, index: number) => (
              <article class={`w-full reveal delay-${(index + 1) * 100}`}>
                <BlogCard
                  title={post.title}
                  excerpt={post.excerpt || ""}
                  slug={post.slug || ""}
                  blogBasePath={localeBlogPath}
                  readMoreText={localizedStaticData.home.blog.readMore}
                  coverImage={post.coverImage}
                />
              </article>
            ))}
            <div class="reveal delay-300">
              <a
                href={localeBlogPath}
                class="font-bold hover:text-link-hover transition-all mt-4"
              >
                {localizedStaticData.home.blog.viewAll}
              </a>
            </div>
          </div>
        </section>
      )
    }

    <section id="contact" class="w-full reveal mb-16" aria-labelledby="contact-heading">
      <h2 id="contact-heading" class="sr-only">{locale === "es" ? "Contacto" : "Contact"}</h2>
      <ContactForm
        client:visible
        email="connect@johandercampos.site"
        labels={{
          heading: localizedStaticData.home.contact.title,
          subheading: localizedStaticData.home.contact.subtitle,
          copyEmailAriaLabel:
            locale === "es" ? "Copiar correo al portapapeles" : "Copy email to clipboard",
          copyEmailSuccess:
            locale === "es" ? "Correo copiado al portapapeles" : "Email copied to clipboard!",
          copyEmailError: locale === "es" ? "No se pudo copiar el correo" : "Failed to copy email",
          nameLabel: localizedStaticData.home.contact.form.nameLabel,
          namePlaceholder: localizedStaticData.home.contact.form.namePlaceholder,
          emailLabel: localizedStaticData.home.contact.form.emailLabel,
          emailPlaceholder: localizedStaticData.home.contact.form.emailPlaceholder,
          messageLabel: localizedStaticData.home.contact.form.messageLabel,
          messagePlaceholder: localizedStaticData.home.contact.form.messagePlaceholder,
          submitButton: localizedStaticData.home.contact.form.submitButton,
          sendingButton: localizedStaticData.home.contact.form.sendingButton,
          configurationError:
            locale === "es"
              ? "Error de configuracion. Intentalo mas tarde."
              : "Configuration error. Please try again later.",
          nameRequired:
            locale === "es" ? "Por favor ingresa tu nombre" : "Please enter your name",
          emailRequired:
            locale === "es" ? "Por favor ingresa tu correo" : "Please enter your email",
          emailInvalid:
            locale === "es"
              ? "Por favor ingresa un correo valido"
              : "Please enter a valid email address",
          messageRequired:
            locale === "es" ? "Por favor ingresa tu mensaje" : "Please enter your message",
          submissionSuccess:
            locale === "es"
              ? "Gracias por tu mensaje"
              : "Thanks for your message!",
          submissionError:
            locale === "es"
              ? "Algo salio mal. Intentalo nuevamente."
              : "Something went wrong. Please try again.",
          unexpectedError:
            locale === "es"
              ? "No se pudo enviar el mensaje. Intentalo nuevamente."
              : "Failed to send message. Please try again.",
        }}
      />
    </section>

    {
      faqContent.questions.length > 0 && (
        <section
          id="faq"
          class="text-center p-2 sm:p-5 w-full md:max-w-180 font-display mt-0 mb-16"
          aria-labelledby="faq-heading"
        >
          <div class="reveal">
            <h2
              id="faq-heading"
              class="text-[clamp(2.5rem,5vw,3.625rem)] font-bold tracking-[0.0625rem] sm:tracking-[0.125rem]"
            >
              {faqContent.title}
            </h2>
            <p class="mt-4 mx-auto max-w-2xl text-left font-sans text-text-muted leading-relaxed">
              {faqContent.intro}
            </p>
          </div>
          <div class="reveal">
            <div class="glassmorphism p-4 sm:p-7.5 rounded-[1.25rem] sm:rounded-[1.875rem] mt-16 transition-all duration-300 cursor-pointer">
              {faqContent.questions.map((faq: { question: string; answer: string }) => (
                <FaqItem
                  client:visible
                  question={faq.question}
                  answer={faq.answer}
                />
              ))}
            </div>
          </div>
        </section>
      )
    }
  </main>

  <Footer
    linkedinUrl={localizedStaticData.header.socials.linkedin}
    githubUrl={localizedStaticData.header.socials.github}
    repoUrl={localizedStaticData.header.repoUrl}
    authorName={localizedStaticData.footer.author}
    copyrightText={localizedStaticData.footer.copyright}
    repoText={localizedStaticData.footer.repoText}
    linkedInAriaLabel={locale === "es" ? "Perfil de LinkedIn" : "LinkedIn Profile"}
    gitHubAriaLabel={locale === "es" ? "Perfil de GitHub" : "GitHub Profile"}
  />
  <BackToTop />
</BaseLayout>
<script
  is:inline
  define:vars={{
    pageTitle,
    pageDescription,
    projectsByCategory,
    faqContent,
    combinedJsonLd,
    featuredBlogPosts,
  }}></script>
