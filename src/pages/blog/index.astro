---
/**
 * @file blog/index.astro
 * @description Blog listing page - data fetching only, UI delegated to BlogListPage.
 */

import BaseLayout from "../../components/templates/BaseTemplate.astro";
import BlogListPage from "../../components/pages/BlogListPage.astro";
import { getBlogPosts } from "../../lib/sanity";
import { generateBreadcrumbSchema } from "../../lib/seo";

const posts = await getBlogPosts();

const siteUrl = "https://developer.johandercampos.com";
const breadcrumbJsonLd = generateBreadcrumbSchema([
  { name: "Home", url: siteUrl },
  { name: "Blog", url: `${siteUrl}/blog` },
]);
---

<BaseLayout
  title="Blog | Johander Campos"
  description="Thoughts, tutorials, and insights on frontend development by Johander Campos."
  jsonLd={breadcrumbJsonLd}
>
  <BlogListPage posts={posts} />
</BaseLayout>
